# SpamShield ML - Comprehensive .gitignore

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.manifest
*.spec

# =============================================================================
# VIRTUAL ENVIRONMENTS
# =============================================================================
env/
venv/
ENV/
env.bak/
venv.bak/
.venv/
conda/

# =============================================================================
# IDE
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
*.rbc
*.rbx
*.sublime-project
*.sublime-workspace
.project
.pydevproject
.settings/
*.tmproj
*.tmproject

# =============================================================================
# IPYTHON NOTEBOOK
# =============================================================================
.ipynb_checkpoints
*.ipynb
!notebooks/*.ipynb

# =============================================================================
# PYSPARK
# =============================================================================
*.log

# =============================================================================
# TESTING
# =============================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# =============================================================================
# DISTRIBUTION
# =============================================================================
build/
dist/
.eggs/
*.egg-info/
*.egg

# =============================================================================
# DATA (MLOps Cookiecutter Pattern)
# =============================================================================
# Keep .gitkeep files but ignore actual data
data/raw/*
!data/raw/.gitkeep
data/interim/*
!data/interim/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/external/*
!data/external/.gitkeep

# =============================================================================
# MODELS
# =============================================================================
# Keep .gitkeep but ignore trained models (they should be versioned separately)
models/*
!models/.gitkeep
*.joblib
*.pkl
*.h5
*.pth
*.onnx
*.pb
*.tflite

# =============================================================================
# LOGS
# =============================================================================
logs/*
!logs/.gitkeep
*.log

# =============================================================================
# ENVIRONMENT VARIABLES
# =============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!*.env.example

# =============================================================================
# FRONTEND / NODE
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache
.stylelintcache

# Next.js
.next/
out/

# Build
build/
dist/

# =============================================================================
# DOCKER
# =============================================================================
.docker/
docker-compose.override.yml

# =============================================================================
# DOCUMENTATION
# =============================================================================
docs/_build/
docs/.doctrees/

# =============================================================================
# JUPYTER
# =============================================================================
.ipynb_checkpoints

# =============================================================================
# OS
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# =============================================================================
# SECRETS & CREDENTIALS
# =============================================================================
*.pem
*.key
*.crt
*.cer
*.pfx
*.p12
credentials
credentials.json
service-account*.json
secrets.json
*.secret
*.secrets

# =============================================================================
# MISCELLANEOUS
# =============================================================================
*.bak
*.tmp
*.temp
.cache/
.parquet
*.feather
*.h5
*.hdf5

# =============================================================================
# CI/CD
# =============================================================================
# Keep workflow files but ignore local overrides
.github/workflows/*.local.yml
